# ─────────────────────────────────────────────────────────────────
#  PromptStudio — environment variables
#  Copy to `.env.local` for local dev, or set in Vercel/Netlify
#  project settings for production.
# ─────────────────────────────────────────────────────────────────

# REQUIRED in production: canonical base URL of the deployed app.
# Used for sitemap.xml, OpenRouter HTTP-Referer, and any future
# absolute-URL stamping.  Do NOT include a trailing slash.
NEXT_PUBLIC_BASE_URL=https://your-deployment.example.com

# Optional alias for HTTP-Referer when you want it to differ from
# NEXT_PUBLIC_BASE_URL.  Falls back to BASE_URL when unset.
NEXT_PUBLIC_APP_URL=https://your-deployment.example.com

# ─── Optional: persistent rate-limit (recommended for production) ──
# Free tier at https://upstash.com (10k req/day, $0).  When both
# values are set, the server uses Redis-backed rate-limiting that
# survives serverless cold-starts.  Without these the server falls
# back to in-memory rate-limiting (per-worker, resets on cold-start).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: error reporting ────────────────────────────────────
# A standard Sentry public DSN.  When set, uncaught route handler
# errors are forwarded to Sentry's store endpoint.  Works with
# self-hosted Sentry.  Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_PROJECT=your-sentry-project

# Alternative / additional error sink: any HTTPS endpoint that
# accepts a JSON POST.  Useful for Slack webhooks, BetterStack,
# Logtail, or a custom collector.  Leave blank to disable.
ERROR_WEBHOOK_URL=
